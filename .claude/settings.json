{
  "extraKnownMarketplaces": {
    "openaccountants": {
      "source": {
        "source": "github",
        "repo": "openaccountants/openaccountants"
      }
    }
  },
  "enabledPlugins": {
    "openaccountants@openaccountants": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/worktree-setup.sh"
          }
        ]
      }
    ]
  }
}
