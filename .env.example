# Secrets the MCP servers read from the environment.
#
# Do NOT put real values in this file. Copy them either into the shell you
# launch Claude Code from, or into the "env" block of .claude/settings.local.json
# (both are gitignored). This file documents the full list; it ships with empty
# values on purpose.

# YNAB — required. Create a personal access token at:
#   https://app.ynab.com/settings/developer
YNAB_API_TOKEN=

# YNAB default budget. Used when a tool call omits budgetId.
# Run the list_budgets tool to find your budget IDs.
YNAB_BUDGET_ID=

# Wave — optional. Full access token for read-only access to your Wave books.
WAVE_FULL_ACCESS_TOKEN=
# Optional default Wave business id (run list_businesses to find it).
WAVE_BUSINESS_ID=

# Personal data vault — optional. Absolute path to a local source of truth
# (e.g. an Obsidian vault). Leave unset to disable.
PERSONAL_VAULT_PATH=

# SnapTrade (Fidelity) needs nothing here — it authenticates over OAuth.
# Run /mcp, pick snaptrade, and approve read-only access in the browser.
